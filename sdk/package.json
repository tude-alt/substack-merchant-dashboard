{
  "name": "@subflow/sdk",
  "version": "0.1.0",
  "description": "Thin TypeScript SDK for the Subflow recurring billing API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "subflow",
    "billing",
    "subscriptions",
    "nigeria",
    "saas"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
